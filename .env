# ============================================================
# Elasticsearch 配置（BM25 关键词检索）
# ============================================================
# ES 服务地址（Docker 内部用服务名 elasticsearch，本机开发用 localhost）
ES_HOST=elasticsearch
ES_PORT=9200
# 建索引超时（秒）；IK+ngram 首次创建可能 >10s，默认 120
# ES_REQUEST_TIMEOUT=120

# ============================================================
# Milvus 配置（向量检索）
# ============================================================
# Milvus 服务地址（Docker 内部用服务名 milvus，本机开发用 localhost）
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ============================================================
# Embedding 向量化（远程 API，OpenAI 兼容 /v1/embeddings）
# ============================================================
# API 地址（如硅基流动、OpenAI 等）
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
# API Key（必填）
EMBEDDING_API_KEY=sk-abzknxljsovybwscscrdwkivcmpzmqbrziuxhctcwnnxyocm
# 模型名称
EMBEDDING_API_MODEL=Qwen/Qwen3-Embedding-8B
# 向量维度（默认 4096，需与模型输出一致）
EMBEDDING_DIM=4096
# 批量请求条数
# EMBEDDING_BATCH=32

# DNS 服务器地址
DNS_SERVER=223.5.5.5
